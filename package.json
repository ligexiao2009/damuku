{
  "name": "b-video-player",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "overlay": "electron electron/main.js",
    "overlay:dev": "OVERLAY_SERVER=http://localhost:3000 electron electron/main.js",
    "dist": "electron-builder build --mac dmg --win nsis",
    "dist:mac": "electron-builder build --mac dmg",
    "dist:win": "electron-builder build --win nsis"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "fast-xml-parser": "^4.4.0",
    "protobufjs": "^8.0.1"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "com.bvideo.danmaku-overlay",
    "productName": "B站弹幕外挂",
    "files": [
      "electron/**/*",
      "public/overlay.html",
      "public/js/danmaku-core.js",
      "public/js/overlay.js",
      "public/css/overlay.css",
      "server.js",
      "routes/**/*",
      "cache/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  }
}
