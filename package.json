{
  "name": "b-video-player",
  "version": "1.2.23",
  "description": "B站弹幕外挂 - 跨播放器通用弹幕悬浮系统",
  "author": "b-video",
  "main": "electron/app.js",
  "scripts": {
    "start": "node server.js",
    "overlay": "electron electron/main.js",
    "overlay:dev": "OVERLAY_SERVER=http://localhost:3000 electron electron/main.js",
    "bump": "npm version patch --no-git-tag-version",
    "dist": "npm run bump && electron-builder build --mac dmg --win nsis",
    "dist:mac": "npm run bump && electron-builder build --mac dmg",
    "dist:win": "npm run bump && electron-builder build --win nsis"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "fast-xml-parser": "^4.5.6",
    "protobufjs": "^8.0.1"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "com.bvideo.danmaku-overlay",
    "productName": "B站弹幕外挂",
    "files": [
      "electron/**/*",
      "public/**/*",
      "server.js",
      "routes/**/*",
      "shared/**/*",
      "services/**/*",
      "utils/**/*",
      "node_modules/**/*",
      "package.json",
      ".env.example"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": "dmg",
      "icon": null
    },
    "win": {
      "target": "nsis"
    }
  }
}
