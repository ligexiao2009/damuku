# 复制本文件为 .env，按需修改配置

# ==================== 服务器配置 ====================

# 服务器监听端口，默认 3000
# PORT=3000

# 日志级别: silent | error | warn | info | debug
# LOG_LEVEL=info

# ==================== 路径配置 ====================

# 视频文件存放目录，默认当前目录下的 videos 文件夹
# VIDEO_DIR=/path/to/your/videos

# 弹幕缓存目录，默认 cache/danmu
# DANMU_CACHE_DIR=/path/to/danmu/cache

# ==================== 弹幕配置 ====================

# 弹幕最大时长（秒），超过此时长的视频不加载弹幕，默认 10800（3小时）
# DANMAKU_MAX_DURATION=10800

# ==================== B站认证 ====================

# B站 SESSDATA，用于请求弹幕和视频元信息。登录 B站后从浏览器 Cookie 中获取
BILI_SESSDATA=your_bilibili_sessdata_here

# ==================== 腾讯体育认证 ====================

# 腾讯体育 Cookie，用于请求直播弹幕。登录 v.qq.com 后用 bookmarklet 提取，留空则由前端传入
# TXSP_COOKIE=qq_domain_video_guid_verify=xxx; ...

# ==================== 缓存清理 ====================

# 播放记录保留天数，默认 30
# PLAYBACK_MAX_AGE=30
